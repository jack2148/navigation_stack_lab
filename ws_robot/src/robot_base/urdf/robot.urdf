<?xml version="1.0"?>
<robot name="diff_robot">

  <!-- REP-103: x forward, y left, z up -->

  <!-- Base frames -->
  <link name="base_footprint"/>
  <link name="base_link"/>

  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Wheels -->
  <link name="left_wheel_link"/>
  <link name="right_wheel_link"/>

  <!-- Wheel separation b = 0.57 m -> y = ±0.285 m -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="0 0.285 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="0 -0.285 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- LiDAR -->
  <!-- IMPORTANT: link name MUST match /scan header.frame_id -->
  <link name="laser"/>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="0.00 0.00 0.30" rpy="0 0 0"/>
  </joint>

  <!-- =========================
       ros2_control integration
       ========================= -->
  <ros2_control name="DiffDriveSystem" type="system">
    <hardware>
      <!-- Must match the plugin exported by pluginlib -->
      <plugin>CanDiffDriveHW</plugin>

      <!-- Hardware params: adjust as needed -->
      <param name="can_iface">can0</param>
      <param name="ticks_per_wheel_rev">440.5</param>
      <param name="wheel_sign_l">-1</param>
      <param name="wheel_sign_r">+1</param>
      <param name="gear_ratio">15</param>
      <param name="max_motor_rpm">30000</param>
    </hardware>

    <joint name="left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

</robot>